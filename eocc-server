#!/usr/bin/env node
/**
 * eocc-server - Headless EOCC event poller, notification dispatcher, and tmux web viewer
 *
 * Usage: eocc-server [--port PORT] [--host HOST]
 *
 * Watches ~/.eocc/logs/events.jsonl for Claude Code session events, dispatches
 * notifications via configured channels (ntfy, webhook, pushover), and serves
 * a web-based tmux viewer for mobile access to Claude's permission prompts.
 *
 * If ttyd is installed, the viewer route launches ttyd for a full terminal
 * experience. Otherwise, falls back to a capture-pane polling viewer.
 *
 * Environment variables:
 *   EOCC_PORT  - HTTP listen port (default: 8080)
 *   EOCC_HOST  - HTTP bind address (default: 0.0.0.0)
 *   EOCC_DIR   - Override ~/.eocc directory
 */

const fs = require("node:fs");
const path = require("node:path");
const os = require("node:os");
const http = require("node:http");
const { execSync, spawn } = require("node:child_process");
const lib = require("./eocc-lib.cjs");

// ---------------------------------------------------------------------------
// Configuration
// ---------------------------------------------------------------------------

function parseArgs() {
  const args = process.argv.slice(2);
  const config = {
    port: parseInt(process.env.EOCC_PORT || "8080", 10),
    host: process.env.EOCC_HOST || "0.0.0.0",
    eoccDir: process.env.EOCC_DIR || path.join(os.homedir(), ".eocc"),
  };
  for (let i = 0; i < args.length; i++) {
    if ((args[i] === "--port" || args[i] === "-p") && args[i + 1]) {
      config.port = parseInt(args[++i], 10);
    } else if ((args[i] === "--host" || args[i] === "-h") && args[i + 1]) {
      config.host = args[++i];
    } else if (args[i] === "--help") {
      console.log("Usage: eocc-server [--port PORT] [--host HOST]");
      console.log("");
      console.log("Options:");
      console.log("  --port, -p  HTTP listen port (default: 8080, env: EOCC_PORT)");
      console.log("  --host, -h  HTTP bind address (default: 0.0.0.0, env: EOCC_HOST)");
      console.log("");
      console.log("Environment:");
      console.log("  EOCC_DIR    Override ~/.eocc directory");
      process.exit(0);
    }
  }
  return config;
}

// ---------------------------------------------------------------------------
// Logging
// ---------------------------------------------------------------------------

function log(category, msg) {
  const ts = new Date().toISOString().slice(11, 19);
  console.log(`[${ts}] [${category}] ${msg}`);
}

// ---------------------------------------------------------------------------
// tmux helpers
// ---------------------------------------------------------------------------

function validatePaneId(paneId) {
  return /^%\d+$/.test(paneId);
}

function tmuxCapture(paneId) {
  return execSync(`tmux capture-pane -p -e -S - -E - -t ${paneId}`, {
    encoding: "utf8",
    timeout: 5000,
  });
}

function tmuxSendKeys(paneId, keys) {
  // Escape single quotes in keys for shell safety
  const escaped = keys.replace(/'/g, "'\\''");
  execSync(`tmux send-keys -t ${paneId} '${escaped}'`, { timeout: 5000 });
}

function findTtyd() {
  try {
    return execSync("which ttyd", { encoding: "utf8", timeout: 3000 }).trim();
  } catch {
    return null;
  }
}

