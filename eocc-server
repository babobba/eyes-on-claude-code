// ---------------------------------------------------------------------------
// Dashboard HTML
// ---------------------------------------------------------------------------

const STATUS_EMOJI = {
  active: "\u{1F7E2}",
  waiting_permission: "\u{1F510}",
  waiting_input: "\u{23F3}",
  completed: "\u{2705}",
};

const STATUS_LABELS = {
  active: "Active",
  waiting_permission: "Waiting for permission",
  waiting_input: "Waiting for input",
  completed: "Completed",
};

function buildDashboardHtml(sessions) {
  const entries = Object.values(sessions);
  // Sort: waiting states first, then active, then completed
  const order = { waiting_permission: 0, waiting_input: 1, active: 2, completed: 3 };
  entries.sort((a, b) => (order[a.status] ?? 9) - (order[b.status] ?? 9));

  let rows = "";
  if (entries.length === 0) {
    rows = `<tr><td colspan="4" style="text-align:center;color:#666;padding:32px">No active sessions</td></tr>`;
  } else {
    for (const s of entries) {
      const emoji = STATUS_EMOJI[s.status] || "";
      const label = STATUS_LABELS[s.status] || s.status;
      const pane = s.tmux_pane ? htmlEscape(s.tmux_pane) : "";
      const viewerLink = s.tmux_pane
        ? `<a href="/tmux/${encodeURIComponent(s.tmux_pane)}" style="color:#6c5ce7">Open viewer</a>`
        : `<span style="color:#555">no pane</span>`;
      const age = s.updated_at ? relativeTime(s.updated_at) : "";
      rows += `<tr>
        <td>${emoji} ${htmlEscape(s.project_name)}</td>
        <td>${label}</td>
        <td>${viewerLink}${pane ? ` <span style="color:#555">(${pane})</span>` : ""}</td>
        <td style="color:#666">${age}</td>
      </tr>`;
    }
  }

  return `<!DOCTYPE html>
