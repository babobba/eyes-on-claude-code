// ---------------------------------------------------------------------------
// ttyd process management
// ---------------------------------------------------------------------------

// Map of paneId -> { process, port } for ttyd instances
const ttydProcesses = new Map();
let nextTtydPort = 7700;

function startTtyd(ttydPath, paneId) {
  if (ttydProcesses.has(paneId)) {
    return ttydProcesses.get(paneId).port;
  }

  const port = nextTtydPort++;
  const child = spawn(ttydPath, [
    "-p", String(port),
    "-o",               // once: exit after client disconnects
    "-t", "fontSize=14",
    "-t", "theme={'background':'#0d0d1a'}",
    "tmux", "attach", "-t", paneId,
  ], {
    stdio: "ignore",
    detached: true,
  });

  child.unref();

  child.on("exit", () => {
    ttydProcesses.delete(paneId);
    log("ttyd", `ttyd for ${paneId} exited`);
  });

  ttydProcesses.set(paneId, { process: child, port });
  log("ttyd", `Started ttyd for ${paneId} on port ${port}`);
  return port;
}

function stopAllTtyd() {
  for (const [paneId, entry] of ttydProcesses) {
    try {
      entry.process.kill();
    } catch {
      // ignore
    }
    ttydProcesses.delete(paneId);
  }
}

// ---------------------------------------------------------------------------
// Event poller
// ---------------------------------------------------------------------------

function startEventPoller(config) {
  const logDir = path.join(config.eoccDir, "logs");
  const eventsPath = path.join(logDir, "events.jsonl");
  const processingPath = path.join(logDir, "events.processing.server.jsonl");
  const settingsPath = path.join(config.eoccDir, "notification_settings.toml");
  const stateFile = path.join(config.eoccDir, "hook_state.json");

  let settings = lib.parseNotificationSettings(settingsPath);
  let settingsMtime = fileMtime(settingsPath);

  // In-memory session state for the /api/sessions endpoint
  const sessions = {};

  log("poller", `Watching ${eventsPath}`);
  log("poller", `${settings ? settings.channels.length : 0} notification channel(s), enabled=${settings ? settings.enabled : false}`);

  const interval = setInterval(() => {
    // Hot-reload settings
    const newMtime = fileMtime(settingsPath);
    if (newMtime !== settingsMtime) {
      settingsMtime = newMtime;
      settings = lib.parseNotificationSettings(settingsPath);
      log("poller", `Settings reloaded: ${settings ? settings.channels.length : 0} channel(s), enabled=${settings ? settings.enabled : false}`);
    }

    // Read events
    const events = readEventsQueue(eventsPath, processingPath);
    if (events.length === 0) return;

    log("poller", `${events.length} event(s)`);

    // Capture old statuses
    const oldStatuses = {};
    for (const [key, s] of Object.entries(sessions)) {
      oldStatuses[key] = s.status;
    }

    // Apply events to in-memory session state
    for (const event of events) {
      const key = event.project_dir || event.project_name;
      const status = lib.mapEventToStatus(event.event, event.notification_type);

      if (status === null) {
        delete sessions[key];
        continue;
      }
      if (status === undefined) continue;

      sessions[key] = {
        project_name: event.project_name,
        project_dir: event.project_dir,
        status,
        last_event: event.event,
        waiting_for: event.message || event.tool_name || "",
        tmux_pane: event.tmux_pane || (sessions[key] && sessions[key].tmux_pane) || "",
        session_id: event.session_id,
        updated_at: event.timestamp,
      };
    }

    // Dispatch notifications
    if (!settings || !settings.enabled) return;
    if (!settings.channels || settings.channels.length === 0) return;

    const hookState = lib.loadHookState(stateFile);
    let stateChanged = false;

    for (const [key, session] of Object.entries(sessions)) {
      const oldStatus = oldStatuses[key] || null;
      const newStatus = session.status;

      if (oldStatus === newStatus) continue;

      // Update hook state
      const prev = hookState.sessions[key];
      hookState.sessions[key] = {
        status: newStatus,
        last_notified: prev ? prev.last_notified : null,
      };
      stateChanged = true;

      const { enabled, notifyOn } = lib.resolveForProject(settings, session.project_dir);
      if (!enabled || !notifyOn.includes(newStatus)) continue;

      if (settings.cooldown_seconds && prev && prev.last_notified) {
        const elapsed = (Date.now() - prev.last_notified) / 1000;
        if (elapsed < settings.cooldown_seconds) continue;
      }

      const transport = {
        type: "local",
        host: "",
        port: "22",
        user: "",
        tmux_session: "",
        tmux_pane: session.tmux_pane,
        viewer_url: `http://localhost:${config.port}`,
      };

      const notification = lib.buildNotification(
        settings,
        session.project_name,
        session.project_dir,
        newStatus,
        session.waiting_for,
        transport
      );

      lib.dispatchToChannels(settings, notification).then((results) => {
        const ok = results.filter((r) => r.ok).length;
        const fail = results.length - ok;
        log("notify", `${session.project_name}: ${oldStatus || "new"} -> ${newStatus} (${ok} ok, ${fail} fail)`);
      });

      hookState.sessions[key].last_notified = Date.now();
    }

    if (stateChanged) {
      lib.saveHookState(stateFile, hookState);
    }
  }, 1000);

  return { interval, sessions };
}

function fileMtime(filePath) {
  try {
    return fs.statSync(filePath).mtimeMs;
  } catch {
    return null;
  }
}

function readEventsQueue(eventsPath, processingPath) {
  if (!fs.existsSync(eventsPath)) return [];

  try {
    fs.renameSync(eventsPath, processingPath);
  } catch {
    return [];
  }

  let content;
  try {
    content = fs.readFileSync(processingPath, "utf8");
  } catch {
    return [];
  }

  try {
    fs.unlinkSync(processingPath);
  } catch {
    // ignore
  }

  return content
    .split("\n")
    .filter((line) => line.trim())
    .map((line) => {
      try {
        return JSON.parse(line);
      } catch {
        return null;
      }
    })
    .filter(Boolean);
}

// ---------------------------------------------------------------------------
// HTTP server
// ---------------------------------------------------------------------------

function startHttpServer(config, sessions) {
  const ttydPath = findTtyd();
  if (ttydPath) {
    log("http", `ttyd found at ${ttydPath} — full terminal viewer available`);
  } else {
    log("http", "ttyd not found — using capture-pane fallback viewer");
  }

  const server = http.createServer((req, res) => {
    const parsedUrl = new URL(req.url, `http://${req.headers.host}`);
    const pathname = parsedUrl.pathname;

    // GET /tmux/:paneId — web viewer (ttyd redirect or fallback HTML)
    const tmuxViewerMatch = pathname.match(/^\/tmux\/(.+)$/);
    if (req.method === "GET" && tmuxViewerMatch) {
      const paneId = decodeURIComponent(tmuxViewerMatch[1]);
      if (!validatePaneId(paneId)) {
        res.writeHead(400, { "Content-Type": "text/plain" });
        res.end("Invalid pane ID");
        return;
      }

      if (ttydPath) {
        const ttydPort = startTtyd(ttydPath, paneId);
        // Small delay to let ttyd bind, then redirect
        setTimeout(() => {
          const ttydHost = req.headers.host.split(":")[0];
          res.writeHead(302, { Location: `http://${ttydHost}:${ttydPort}/` });
          res.end();
        }, 300);
      } else {
        const html = VIEWER_HTML.replace(/\{\{PANE_ID\}\}/g, htmlEscape(paneId));
        res.writeHead(200, { "Content-Type": "text/html; charset=utf-8" });
        res.end(html);
      }
      log("http", `GET /tmux/${paneId} -> ${ttydPath ? "ttyd" : "fallback"}`);
      return;
    }

    // GET /api/tmux/:paneId/capture — capture pane content
    const captureMatch = pathname.match(/^\/api\/tmux\/(.+)\/capture$/);
    if (req.method === "GET" && captureMatch) {
      const paneId = decodeURIComponent(captureMatch[1]);
      if (!validatePaneId(paneId)) {
        jsonResponse(res, 400, { error: "Invalid pane ID" });
        return;
      }
      try {
        const content = tmuxCapture(paneId);
        res.writeHead(200, {
          "Content-Type": "text/plain; charset=utf-8",
          "Access-Control-Allow-Origin": "*",
        });
        res.end(content);
      } catch (e) {
        jsonResponse(res, 500, { error: e.message });
      }
      return;
    }

    // POST /api/tmux/:paneId/send — send keys to pane
    const sendMatch = pathname.match(/^\/api\/tmux\/(.+)\/send$/);
    if (req.method === "POST" && sendMatch) {
      const paneId = decodeURIComponent(sendMatch[1]);
      if (!validatePaneId(paneId)) {
        jsonResponse(res, 400, { error: "Invalid pane ID" });
        return;
      }
      let body = "";
      req.on("data", (chunk) => (body += chunk));
      req.on("end", () => {
        try {
          const { keys } = JSON.parse(body);
          if (!keys) {
            jsonResponse(res, 400, { error: "Missing keys field" });
            return;
          }
          tmuxSendKeys(paneId, keys);
          jsonResponse(res, 200, { ok: true });
          log("http", `POST /api/tmux/${paneId}/send keys=${JSON.stringify(keys)}`);
        } catch (e) {
          jsonResponse(res, 500, { error: e.message });
        }
      });
      return;
    }

    // GET /api/sessions — current session state
    if (req.method === "GET" && pathname === "/api/sessions") {
      jsonResponse(res, 200, sessions);
      return;
    }

    // GET / — health check
    if (req.method === "GET" && pathname === "/") {
      res.writeHead(200, { "Content-Type": "text/plain" });
      res.end("eocc-server\n");
      return;
    }

    res.writeHead(404, { "Content-Type": "text/plain" });
    res.end("Not Found\n");
  });

  server.listen(config.port, config.host, () => {
    log("http", `Listening on ${config.host}:${config.port}`);
  });

  return server;
}

function jsonResponse(res, status, data) {
  res.writeHead(status, { "Content-Type": "application/json" });
  res.end(JSON.stringify(data));
}

function htmlEscape(s) {
  return s
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#x27;");
}

// ---------------------------------------------------------------------------
// Main
// ---------------------------------------------------------------------------

function main() {
  const config = parseArgs();

  // Ensure directories exist
  fs.mkdirSync(path.join(config.eoccDir, "logs"), { recursive: true });

  const { sessions } = startEventPoller(config);
  startHttpServer(config, sessions);

  // Graceful shutdown
  function shutdown() {
    log("server", "Shutting down...");
    stopAllTtyd();
    process.exit(0);
  }
  process.on("SIGINT", shutdown);
  process.on("SIGTERM", shutdown);

  log("server", "eocc-server started");
}

main();
